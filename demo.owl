        <obo:IAO_0000112 xml:lang="en">‘F’ (intended to refer to a female biological sex), 
‘F’ (intended to refer to a female gender role), 
‘Female’, ‘Woman’, ‘0’ (intended to refer to a female biological sex), 
‘1’ (intended to refer to a female biological role), 
‘M’, ‘Male’, ‘Man’, ‘0’ (intended to refer to a male biological role), 
‘HF’ (intended to refer to a hermaphrodite sex), 
‘Intersex’, ‘Hermaphrodite’, ‘Pseudo-hermaphrodite’, ‘Non-binary’, ‘Trigender’, ‘Agender’, ‘Genderfluid’, ‘Other’ (intended to refer to a gender role not-listed in the list containing this data item)</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">An information content entity that is intended to denote a biological sex or a gender identity.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">biological sex or gender identity datum</rdfs:label>
    </owl:Class>
    


