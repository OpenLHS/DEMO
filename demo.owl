    <owl:Class rdf:about="http://griis.ca/GRIIS_TEMP_00000004">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OMRSE_00000133"/>
        <obo:IAO_0000112 xml:lang="en">‘Non-binary’, ‘Trigender’, ‘Agender’, ‘Genderfluid’, ‘2’ (intended to refer to a non-binary gender role)</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A gender identity datum resulting from a gender identification process in which ‘non-binary’ is selected based on the participant&apos;s subjective sense of gender.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">non-binary gender identity datum</rdfs:label>
    </owl:Class>
    


