    <!-- http://purl.obolibrary.org/obo/DEMO_0000017 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DEMO_0000017">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/DEMO_0000044"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
