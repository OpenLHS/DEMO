############################
#   Classes
############################

# Class: <http://griis.ca/GRIIS_TEMP_00000004> (non-binary gender identity datum)

AnnotationAssertion(obo:IAO_0000112 <http://griis.ca/GRIIS_TEMP_00000004> "‘Non-binary’, ‘Trigender’, ‘Agender’, ‘Genderfluid’, ‘2’ (intended to refer to a non-binary gender role)"@en)
AnnotationAssertion(obo:IAO_0000115 <http://griis.ca/GRIIS_TEMP_00000004> "A gender identity datum resulting from a gender identification process in which ‘non-binary’ is selected based on the participant's subjective sense of gender."@en)
AnnotationAssertion(rdfs:label <http://griis.ca/GRIIS_TEMP_00000004> "non-binary gender identity datum"@en)
SubClassOf(<http://griis.ca/GRIIS_TEMP_00000004> obo:OMRSE_00000133)

# Class: obo:DEMO_0000013 (DEPRECATED biological sex specification)

AnnotationAssertion(rdfs:comment obo:DEMO_0000013 "VO:Biological sex datum is the preferred class."^^xsd:string)
AnnotationAssertion(rdfs:label obo:DEMO_0000013 "DEPRECATED biological sex specification"@en)
AnnotationAssertion(rdfs:label obo:DEMO_0000013 "DEPRECATED spécification de sexe biologique"@fr)
AnnotationAssertion(owl:deprecated obo:DEMO_0000013 "true"^^xsd:boolean)

# Class: obo:DEMO_0000017 (human birth date specification)

AnnotationAssertion(obo:IAO_0000112 obo:DEMO_0000017 "Date of birth: 1802/02/26"@en)
AnnotationAssertion(obo:IAO_0000115 obo:DEMO_0000017 "A temporal specification which is about the birth date of a person."@en)
AnnotationAssertion(obo:IAO_0000115 obo:DEMO_0000017 "Une spécification temporelle qui est à propos de la date de naissance d'une personne."@fr)
AnnotationAssertion(rdfs:comment obo:DEMO_0000017 "AB: Cette classe est toujours délicate. N'importe quelle date specification est à propos d'un intervalle de 24h pendant lequel une personne naît, donc devrait être une human birth date specification. L'idée, c'est qu'une ICE est une human birth date specification lorsqu'elle joue le rôle d'indiquer la date de naissance de quelqu'un. Mais on n'a pas encore formalisé les rôles d'ICE. Je laisserais comme ça pour l'instant, mais se souvenir que c'est problématique."@fr)
AnnotationAssertion(rdfs:label obo:DEMO_0000017 "human birth date specification"@en)
AnnotationAssertion(rdfs:label obo:DEMO_0000017 "spécification de date de naissance d'être humain"@fr)
SubClassOf(obo:DEMO_0000017 obo:DEMO_0000044)
SubClassOf(obo:DEMO_0000017 ObjectSomeValuesFrom(obo:IAO_0000136 ObjectIntersectionOf(obo:BFO_0000015 ObjectSomeValuesFrom(obo:RO_0000057 obo:NCBITaxon_9606))))
SubClassOf(obo:DEMO_0000017 ObjectSomeValuesFrom(obo:IAO_0000219 obo:BFO_0000038))

# Class: obo:DEMO_0000018 (spécification de date de décès d'humain)

AnnotationAssertion(obo:IAO_0000112 obo:DEMO_0000018 "Date of death: 1885/05/22"@en)
AnnotationAssertion(obo:IAO_0000115 obo:DEMO_0000018 "A temporal specification which is about the date of death of a person."@en)
AnnotationAssertion(obo:IAO_0000115 obo:DEMO_0000018 "Une spécification de date de décès qui est à propos de la date de décès d'un être humain."@fr)
AnnotationAssertion(rdfs:comment obo:DEMO_0000018 "cf. commentaire 'human birth date specification'"@fr)
AnnotationAssertion(rdfs:label obo:DEMO_0000018 "human death date specification"@en)
AnnotationAssertion(rdfs:label obo:DEMO_0000018 "spécification de date de décès d'humain"@fr)
SubClassOf(obo:DEMO_0000018 obo:DEMO_0000044)
SubClassOf(obo:DEMO_0000018 ObjectSomeValuesFrom(obo:IAO_0000136 ObjectIntersectionOf(obo:BFO_0000015 ObjectSomeValuesFrom(obo:RO_0000057 obo:NCBITaxon_9606))))
SubClassOf(obo:DEMO_0000018 ObjectSomeValuesFrom(obo:IAO_0000219 obo:BFO_0000038))

# Class: obo:DEMO_0000019 (DEPRECATED spécification de sexe biologique d'humain)

AnnotationAssertion(rdfs:label obo:DEMO_0000019 "DEPRECATED human biological sex specification"@en)
AnnotationAssertion(rdfs:label obo:DEMO_0000019 "DEPRECATED spécification de sexe biologique d'humain"@fr)
AnnotationAssertion(owl:deprecated obo:DEMO_0000019 "true"^^xsd:boolean)

# Class: obo:DEMO_0000025 (beginning process boundary)

AnnotationAssertion(rdfs:label obo:DEMO_0000025 "beginning process boundary"@en)
SubClassOf(obo:DEMO_0000025 obo:BFO_0000035)

# Class: obo:DEMO_0000026 (ending process boundary)

AnnotationAssertion(rdfs:label obo:DEMO_0000026 "ending process boundary"@en)
SubClassOf(obo:DEMO_0000026 obo:BFO_0000035)

# Class: obo:DEMO_0000044 (temporal specification)

AnnotationAssertion(obo:IAO_0000112 obo:DEMO_0000044 "'Date of birth: 1802/02/26'

'Date of death: 1885/05/22'"@en)
AnnotationAssertion(obo:IAO_0000115 obo:DEMO_0000044 "An information content entity which is about a specific period of time."@en)
AnnotationAssertion(rdfs:label obo:DEMO_0000044 "temporal specification"@en)
EquivalentClasses(obo:DEMO_0000044 ObjectIntersectionOf(obo:IAO_0000030 ObjectSomeValuesFrom(obo:IAO_0000219 obo:BFO_0000038)))

# Class: obo:DEMO_0000045 (biological sex or gender identity datum)

AnnotationAssertion(obo:IAO_0000112 obo:DEMO_0000045 "‘F’ (intended to refer to a female biological sex), 
‘F’ (intended to refer to a female gender role), 
‘Female’, ‘Woman’, ‘0’ (intended to refer to a female biological sex), 
‘1’ (intended to refer to a female biological role), 
‘M’, ‘Male’, ‘Man’, ‘0’ (intended to refer to a male biological role), 
‘HF’ (intended to refer to a hermaphrodite sex), 
‘Intersex’, ‘Hermaphrodite’, ‘Pseudo-hermaphrodite’, ‘Non-binary’, ‘Trigender’, ‘Agender’, ‘Genderfluid’, ‘Other’ (intended to refer to a gender role not-listed in the list containing this data item)"@en)
AnnotationAssertion(obo:IAO_0000115 obo:DEMO_0000045 "An information content entity that is intended to denote a biological sex or a gender identity."@en)
AnnotationAssertion(rdfs:label obo:DEMO_0000045 "biological sex or gender identity datum"@en)
EquivalentClasses(obo:DEMO_0000045 ObjectUnionOf(obo:OMRSE_00000133 obo:VO_0001194))
SubClassOf(obo:DEMO_0000045 obo:IAO_0000030)

# Class: obo:DEMO_0000046 (female biological sex or gender identity datum)

AnnotationAssertion(obo:IAO_0000112 obo:DEMO_0000046 "‘F’ (intended to refer to a female biological sex), 
‘F’ (intended to refer to a female gender identity), 
‘W’, ‘Female’, ‘Woman’, ‘0’ (intended to refer to a female biological sex), 
‘1’ (intended to refer to a female biological role)"@en)
AnnotationAssertion(obo:IAO_0000115 obo:DEMO_0000046 "A biological sex or gender identity datum that is intended to denote a female biological sex or a female gender identity."@en)
AnnotationAssertion(rdfs:label obo:DEMO_0000046 "female biological sex or gender identity datum"@en)
SubClassOf(obo:DEMO_0000046 obo:DEMO_0000045)

# Class: obo:DEMO_0000047 (male biological sex or gender identity datum)

AnnotationAssertion(obo:IAO_0000112 obo:DEMO_0000047 "‘M’ (intended to refer to a male biological sex), 
‘M’ (intended to refer to a male gender identity), 
‘Male’, ‘Man’, ‘1’ (intended to refer to a male biological sex), 
‘0’ (intended to refer to a male biological role)"@en)
AnnotationAssertion(obo:IAO_0000115 obo:DEMO_0000047 "A biological sex or gender identity datum that is intended to denote a male biological sex or a male gender identity."@en)
AnnotationAssertion(rdfs:label obo:DEMO_0000047 "male biological sex or gender identity datum"@en)
SubClassOf(obo:DEMO_0000047 obo:DEMO_0000045)

# Class: obo:DEMO_0000048 (intersex biological sex or non-binary gender identity datum)

AnnotationAssertion(obo:IAO_0000112 obo:DEMO_0000048 "‘I’ (intended to refer to an intersex biological sex), 
‘Intersex’, ‘Hermaphrodite’, ‘Pseudo-hermaphrodite’, 
‘2’ (intended to refer to an intersex biological sex). 
‘Non-binary’, ‘Trigender’, ‘Agender’, ‘Genderfluid’, ‘2’ (intended to refer to a non-binary gender role)"@en)
AnnotationAssertion(obo:IAO_0000115 obo:DEMO_0000048 "A biological sex or gender identity datum that is intended to denote a intersex biological sex or a non-binary gender identity."@en)
AnnotationAssertion(rdfs:label obo:DEMO_0000048 "intersex biological sex or non-binary gender identity datum"@en)
SubClassOf(obo:DEMO_0000048 obo:DEMO_0000045)

# Class: obo:OBI_0000011 (planned process)

SubClassOf(obo:OBI_0000011 obo:BFO_0000015)

# Class: obo:PATO_0000001 (quality)

SubClassOf(obo:PATO_0000001 obo:BFO_0000020)

# Class: obo:VO_0000613 (male biological sex datum)

AnnotationAssertion(obo:IAO_0000112 obo:VO_0000613 "‘M’ (intended to refer to a male biological sex), 
‘Male’, ‘Man’, ‘1’ (intended to refer to a male biological sex)"@en)
AnnotationAssertion(obo:IAO_0000115 obo:VO_0000613 "A biological sex measurement datum that is intended to denote a male biological sex."@en)
AnnotationAssertion(rdfs:label obo:VO_0000613 "male biological sex datum"@en)
SubClassOf(obo:VO_0000613 obo:VO_0001194)

# Class: obo:VO_0004895 (female biological sex datum)

AnnotationAssertion(obo:IAO_0000112 obo:VO_0004895 "‘F’ (intended to refer to a female biological sex),
‘Female’, ‘Woman’, ‘0’ (intended to refer to a female biological sex)"@en)
AnnotationAssertion(obo:IAO_0000115 obo:VO_0004895 "A biological sex measurement datum that is intended to denote a female biological sex."@en)
AnnotationAssertion(rdfs:label obo:VO_0004895 "female biological sex datum"@en)
SubClassOf(obo:VO_0004895 obo:VO_0001194)

# Class: obo:VO_0004896 (intersex biological sex datum)

AnnotationAssertion(obo:IAO_0000112 obo:VO_0004896 "‘I’ (intended to refer to an intersex biological sex), 
‘Intersex’, ‘Hermaphrodite’, ‘Pseudo-hermaphrodite’, ‘2’ (intended to refer to an intersex biological sex)"@en)
AnnotationAssertion(obo:IAO_0000115 obo:VO_0004896 "A biological sex measurement datum that is intended to denote an intersex biological sex."@en)
AnnotationAssertion(rdfs:label obo:VO_0004896 "intersex biological sex datum"@en)
SubClassOf(obo:VO_0004896 obo:VO_0001194)


AnnotationAssertion(obo:IAO_0000115 obo:IAO_0020000 "Une entité de contenu informationnel qui est le résultat d'un processus de dénomination d'une entité et dont l'usage est partagé par un groupe d'individus qui s'en servent pour référer à cette entité."@fr)
AnnotationAssertion(rdfs:label obo:IAO_0020000 "nom propre"@fr)
AnnotationAssertion(obo:IAO_0000115 ontoneo:ONTONEO_00000259 "An information content entity which is about a date."@en)
AnnotationAssertion(obo:IAO_0000115 ontoneo:ONTONEO_00000259 "Une entité de contenu informationnel qui est à propos d'une date."@fr)
AnnotationAssertion(rdfs:label ontoneo:ONTONEO_00000259 "spécification de date"@fr)
AnnotationAssertion(obo:IAO_0000115 ontoneo:ONTONEO_00000263 "A date content which is about a birth date."@en)
AnnotationAssertion(obo:IAO_0000115 ontoneo:ONTONEO_00000263 "Une spécification de date qui est à propos d'une date de naissance."@fr)
AnnotationAssertion(rdfs:label ontoneo:ONTONEO_00000263 "spécification de date de naissance"@fr)
