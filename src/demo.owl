Import(<http://purl.obolibrary.org/obo/ro/core.owl>)
Annotation(dc:creator "Adrien Barton")
Annotation(dc:creator "Jean-François Éthier")
Annotation(dc:creator "Olivier Grenier")
Annotation(dc:creator "Paul Fabry")
Annotation(rdfs:comment "An ontology for identification of individuals in the healthcare domain."@en)

