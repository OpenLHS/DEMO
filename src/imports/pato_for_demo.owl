AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/PATO_0001894> "An organismal quality inhering in a bearer by virtue of the bearer's physical expression of sexual characteristics.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/PATO_0001894> "quality")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/PATO_0001894> "PATO:0001894")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/PATO_0001894> <http://purl.obolibrary.org/obo/pato#attribute_slim>)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/PATO_0001894> <http://purl.obolibrary.org/obo/pato.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/PATO_0001894> "phenotypic sex")
SubClassOf(<http://purl.obolibrary.org/obo/PATO_0001894> <http://purl.obolibrary.org/obo/PATO_0000047>)

# Class: <http://purl.obolibrary.org/obo/PATO_0001995> (organismal quality)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PATOC:CJM"^^xsd:string) <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/PATO_0001995> "A quality that inheres in an entire organism or part of an organism.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/PATO_0001995> "quality")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/PATO_0001995> "PATO:0001995")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/PATO_0001995> <http://purl.obolibrary.org/obo/pato.owl>)
