# Class: <http://purl.obolibrary.org/obo/PATO_0020000> (genotypic sex)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PATOC:MAH"^^xsd:string) <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/PATO_0020000> "A biological sex quality inhering in an individual based upon genotypic composition of sex chromosomes.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <http://purl.obolibrary.org/obo/PATO_0020000> "mah")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/PATO_0020000> "quality")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/PATO_0020000> "PATO:0020000")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/PATO_0020000> "Note that the chromosomal constitution of genotypic sex varies in different organisms. In human, we have XY, XX, though abnormal XXY, X0, XYY, and other combinations are possible.")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/PATO_0020000> <http://purl.obolibrary.org/obo/pato.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/PATO_0020000> "genotypic sex")
SubClassOf(<http://purl.obolibrary.org/obo/PATO_0020000> <http://purl.obolibrary.org/obo/PATO_0000047>)

# Class: <http://purl.obolibrary.org/obo/PATO_0020001> (male genotypic sex)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PATOC:MAH"^^xsd:string) <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/PATO_0020001> "A biological sex quality inhering in an individual based upon genotypic composition that confers the capability for an organism to differentiate male gonads.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <http://purl.obolibrary.org/obo/PATO_0020001> "mah")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/PATO_0020001> "quality")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/PATO_0020001> "PATO:0020001")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/PATO_0020001> "Note that the chromosomal constitution of genotypic sex varies in different organisms. In human, this would be XY, though abnormal XXY and XYY would also result in a male phenotypic outcome.")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/PATO_0020001> <http://purl.obolibrary.org/obo/pato.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/PATO_0020001> "male genotypic sex")
SubClassOf(<http://purl.obolibrary.org/obo/PATO_0020001> <http://purl.obolibrary.org/obo/PATO_0020000>)

# Class: <http://purl.obolibrary.org/obo/PATO_0020002> (female genotypic sex)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PATOC:MAH"^^xsd:string) <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/PATO_0020002> "A biological sex quality inhering in an individual or a population based upon genotypic composition that confers the capability for an organism to differentiate female gonads.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#created_by> <http://purl.obolibrary.org/obo/PATO_0020002> "mah")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/PATO_0020002> "quality")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/PATO_0020002> "PATO:0020002")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/PATO_0020002> "Note that the chromosomal constitution of genotypic sex varies in different organisms. In human, this would be XX, though abnormal X0 and XXX would also result in a female phenotypic outcome.")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/PATO_0020002> <http://purl.obolibrary.org/obo/pato.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/PATO_0020002> "female genotypic sex")
SubClassOf(<http://purl.obolibrary.org/obo/PATO_0020002> <http://purl.obolibrary.org/obo/PATO_0020000>)


