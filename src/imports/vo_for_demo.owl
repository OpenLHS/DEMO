# Class: <http://purl.obolibrary.org/obo/VO_0000613> (male biological sex datum)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> <http://purl.obolibrary.org/obo/VO_0000613> "‘M’ (intended to refer to a male biological sex), ‘Male’, ‘Man’, ‘1’ (intended to refer to a male biological sex)")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/VO_0000613> "A biological sex datum that represents the biological sex of an animal (including human) as being male.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/VO_0000613> "Paul Fabry, Oliver He")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/VO_0000613> <http://purl.obolibrary.org/obo/vo.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/VO_0000613> "male biological sex datum"@en)
SubClassOf(<http://purl.obolibrary.org/obo/VO_0000613> <http://purl.obolibrary.org/obo/VO_0001194>)

# Class: <http://purl.obolibrary.org/obo/VO_0001194> (biological sex datum)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/VO_0001194> "A measurement datum that represents the biological sex of an animal. The result can be represented using a discretized digit, for example, 0 = female; 1 = male.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/VO_0001194> "YH")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/VO_0001194> "He Y, Xiang Z, Todd T, Courtot M, Brinkman R, Zheng J, Stoeckert CJ, Malone J, Rocca-Serra P, Sansone S, Fostel J, Soldatova LN, Peters B, Rutternberg A. Ontology representation and ANOVA analysis of vaccine protection investigation. Proceeding of Bio-Ontologies 2010: Semantic Applications in Life Sciences, ISMB, July 9-10, 2010. Boston, MA, USA. Full length paper. URL: http://www.hegroup.org/docs/ANOVA_Vaccine_usecase_camera.pdf")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/VO_0001194> "Todd TE, Tibi O, Lin Y, Sayers S, Bronner DN, Xiang Z, He Y. Meta-analysis of variables affecting mouse protection efficacy of whole organism Brucella vaccines and vaccine candidates. BMC Bioinformatics. 2013, 14(Suppl 6):S3. PMID: 23735014. PMCID: PMC3633026. ")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/VO_0001194> <http://purl.obolibrary.org/obo/vo.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/VO_0001194> "biological sex datum")
SubClassOf(<http://purl.obolibrary.org/obo/VO_0001194> <http://purl.obolibrary.org/obo/IAO_0000109>)
SubClassOf(<http://purl.obolibrary.org/obo/VO_0001194> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/IAO_0000136> <http://purl.obolibrary.org/obo/PATO_0000047>))

# Class: <http://purl.obolibrary.org/obo/VO_0004895> (female biological sex datum)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> <http://purl.obolibrary.org/obo/VO_0004895> "‘F’ (intended to refer to a female biological sex), ‘Female’, ‘Woman’, ‘0’ (intended to refer to a female biological sex)")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/VO_0004895> "A biological sex datum that represents the biological sex of an animal (including human) as being female.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/VO_0004895> "Paul Fabry, Oliver He")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/VO_0004895> <http://purl.obolibrary.org/obo/vo.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/VO_0004895> "female biological sex datum"@en)
SubClassOf(<http://purl.obolibrary.org/obo/VO_0004895> <http://purl.obolibrary.org/obo/VO_0001194>)

# Class: <http://purl.obolibrary.org/obo/VO_0004896> (intersex biological sex datum)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000112> <http://purl.obolibrary.org/obo/VO_0004896> "‘I’ (intended to refer to an intersex biological sex), ‘Intersex’, ‘Hermaphrodite’, ‘Pseudo-hermaphrodite’, ‘2’ (intended to refer to an intersex biological sex)")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/VO_0004896> "A biological sex datum that represents the biological sex of an animal (including human) as being intersex.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/VO_0004896> "Paul Fabry, Oliver He")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/VO_0004896> <http://purl.obolibrary.org/obo/vo.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/VO_0004896> "intersex biological sex datum"@en)
SubClassOf(<http://purl.obolibrary.org/obo/VO_0004896> <http://purl.obolibrary.org/obo/VO_0001194>)


